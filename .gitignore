# SSH keys (Docker는 ./secrets 마운트). 폴더는 로컬에서 생성, 저장소에 미포함.
secrets/

# Data (샘플 제외)
data/
!data/samples/

# 파이프라인·로컬 산출물 (RAG는 Chroma만 사용, 배포 시 미전송)
output/

# Chroma: 로컬 파이프라인이 만든 세그먼트 디렉터리(UUID). 레포에는 chroma.sqlite3 등 베이스만 유지.
chromadb/*/


# 앱
APP_ENV=development
APP_DEBUG=true

# CSV
CSV_BATCH_SIZE=100
CSV_MAX_FILE_SIZE_MB=50

# 크롤링
CRAWL_TIMEOUT_SEC=10
CRAWL_MAX_BLOG_LINKS=10
CRAWL_MAX_CHARS_PER_PAGE=3000

# 네이버 검색 API (블로그 URL 수집)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_BLOG_RESULTS_PER_SHOP=10

# Gemini (정제 / RAG 답변)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# MySQL (init_db.sql 스키마)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=aniwhere

# AWS (embed_to_chromadb.py S3 경로 전용 — 파이프라인은 로컬 Chroma만 사용)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-2
S3_BUCKET_NAME=

# 출력 / Chroma / 파이프라인
OUTPUT_DIR=./output
CHROMA_PERSIST_PATH=chromadb
PIPELINE_SLEEP_SEC=15
PIPELINE_MAX_BLOG_LINKS_CRAWL=5

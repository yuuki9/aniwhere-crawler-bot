# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# App Settings
APP_ENV=development
APP_DEBUG=true

# CSV Processing
CSV_BATCH_SIZE=100
CSV_MAX_FILE_SIZE_MB=50

# Gemini Model
GEMINI_MODEL=gemini-flash-latest
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TEMPERATURE=0.3

# Blog Crawling
CRAWL_TIMEOUT_SEC=10.0
CRAWL_MAX_BLOG_LINKS=3
CRAWL_MAX_CHARS_PER_PAGE=1500

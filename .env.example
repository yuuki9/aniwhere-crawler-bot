# 앱
APP_ENV=development
APP_DEBUG=true

# CSV
CSV_BATCH_SIZE=100
CSV_MAX_FILE_SIZE_MB=50

# 크롤링
CRAWL_TIMEOUT_SEC=10
CRAWL_MAX_BLOG_LINKS=10
CRAWL_MAX_CHARS_PER_PAGE=3000

# 네이버 검색 API (블로그 URL 수집)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_BLOG_RESULTS_PER_SHOP=10

# Gemini (정제 / RAG 답변)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# TMDB v3 — AniList 트렌딩/미디어 응답에 한글 표제(koreanTitle) 보강 (선택)
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# MySQL (init_db.sql 스키마)
# 앱 컨테이너 또는 로컬은 MYSQL_HOST/MYSQL_PORT 로 DB에 바로 접속합니다.
#
# 로컬: 보통 MYSQL_HOST=127.0.0.1 또는 Docker Compose DB 서비스명
# VPC 내 EC2: 사설 RDS/DB IP 또는 EC2 호스트(EC_HOST와 동일 호스트 내 MySQL 포함)
#
# CI 배포 SSH 대상(EC2 등) 시크릿은 deploy-ec2.yml 의 EC_HOST 참고(GitHub Actions)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=aniwhere

# AWS (embed_to_chromadb.py S3 경로 전용 — 파이프라인은 로컬 Chroma만 사용)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-2
S3_BUCKET_NAME=

# 출력 / Chroma / 파이프라인
OUTPUT_DIR=./output
CHROMA_PERSIST_PATH=chromadb
# RAG: 유사도 임계값 (선택). 미설정 시 Chroma에 문서만 있으면 항상 RAG. L2 등 컬렉션 메트릭에 맞게 조정.
# RAG_CHROMA_MAX_DISTANCE=
PIPELINE_SLEEP_SEC=15
PIPELINE_MAX_BLOG_LINKS_CRAWL=5

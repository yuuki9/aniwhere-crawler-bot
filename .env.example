# 앱
APP_ENV=development
APP_DEBUG=true

# CSV
CSV_BATCH_SIZE=100
CSV_MAX_FILE_SIZE_MB=50

# 크롤링
CRAWL_TIMEOUT_SEC=10
CRAWL_MAX_BLOG_LINKS=10
CRAWL_MAX_CHARS_PER_PAGE=3000

# 네이버 검색 API (블로그 URL 수집)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_BLOG_RESULTS_PER_SHOP=10

# Gemini (정제 / RAG 답변)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# MySQL (init_db.sql 스키마)
# 프라이빗 서브넷 DB는 베스천 SSH 터널 후 접속:
#   1) PowerShell: .\scripts\mysql-bastion-tunnel.ps1 (값 수정 또는 매개변수로 전달)
#   2) 터널 연 뒤 이 파일에서:
#      - 호스트에서 직실행: MYSQL_HOST=127.0.0.1  MYSQL_PORT=<터널 로컬 포트>
#      - docker compose run: MYSQL_HOST=host.docker.internal  MYSQL_PORT=<동일>
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=aniwhere

# MySQL 베스천 SSH 터널 (로컬·개발 PC에서 사설 DB 붙을 때만. EC2/프로덕션은 같은 VPC면 직접 연결, 터널/PEM 불필요)
# True 일 때 MYSQL_HOST / MYSQL_PORT 는 베스천에서 보이는 사설 DB 주소·포트
MYSQL_USE_SSH_TUNNEL=false
MYSQL_SSH_BASTION=
# MYSQL_SSH_BASTION=ec2-user@1.2.3.4
MYSQL_SSH_BASTION_PORT=22
# host 만 쓸 때 사용자명
MYSQL_SSH_USERNAME=
MYSQL_SSH_PRIVATE_KEY=secrets/aniwhere-key.pem
# PEM 은 ./secrets 에 두고 Docker 는 compose 가 /app/secrets 로 마운트
MYSQL_SSH_PRIVATE_KEY_PASSWORD=

# AWS (embed_to_chromadb.py S3 경로 전용 — 파이프라인은 로컬 Chroma만 사용)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-2
S3_BUCKET_NAME=

# 출력 / Chroma / 파이프라인
OUTPUT_DIR=./output
CHROMA_PERSIST_PATH=chromadb
# RAG: 유사도 임계값 (선택). 미설정 시 Chroma에 문서만 있으면 항상 RAG. L2 등 컬렉션 메트릭에 맞게 조정.
# RAG_CHROMA_MAX_DISTANCE=
PIPELINE_SLEEP_SEC=15
PIPELINE_MAX_BLOG_LINKS_CRAWL=5
